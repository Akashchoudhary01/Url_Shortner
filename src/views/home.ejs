<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL-SHORTNER</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            background-color: #f4f7fc;
            font-family: 'Lucida Sans', Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 900px;
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        .url {
            max-width: 250px;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        form {
            margin: 20px 0;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        input[type="text"] {
            flex: 1;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        button {
            padding: 10px 15px;
            border: none;
            background-color: #0077ff;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background-color: #005ed1;
        }

        a {
            text-decoration: none;
            color: #0077ff;
            margin-right: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        table,
        th,
        td {
            border: 1px solid #ddd;
        }

        th {
            background-color: #0077ff;
            color: white;
            padding: 12px;
        }

        td {
            padding: 10px;
            text-align: center;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        tr:hover {
            background-color: #f1f1f1;
        }
    </style>
</head>

<body>
    <div class=" container">
        <% if (locals.id) { %>
            <p>`URL generated : http://localhost:6969/<%= id%>`</p>
            <p><a href="/">Back to home </a></p>

            <% } %>
                <a href="/login">Login</a>
                <a href="/signup">signup</a>
                <a href="/user/logout">
                    <button>Logout</button>
                </a>
                <form action="/url" method="post">
                    <label for="url">Enter your Original URL</label>
                    <input type="text" name="url" id="url">
                    <button type="submit">Submit</button>
                </form>
                <% if (locals.allUrl) { %>
                    <table>
                        <thead>
                            <th>S. no</th>
                            <th>short id</th>
                            <th>Redirect </th>
                            <th>clicks</th>
                        </thead>
                        <tbody>
                            <% allUrl.forEach((url , index)=> { %>
                                <tr>

                                    <td>
                                        <%= index +1%>
                                    </td>
                                    <td>
                                        <%= url.shortID %>
                                    </td>
                                    <td class="url">
                                        <a href="<%= url.redirectUrl %>" target="_blank">
                                            <%= url.redirectUrl %>
                                        </a>
                                    </td>
                                    <td>
                                        <%= url.visitHistory.length %>
                                    </td>

                                </tr>
                                <% }) %>
                        </tbody>
                    </table>

                    <% } %>
    </div>

</body>

</html>